{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "node_modules/sql.js/dist/**"]
      }
    }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/server.js" },
    { "src": "/(.*)",        "dest": "/server.js" }
  ]
}
